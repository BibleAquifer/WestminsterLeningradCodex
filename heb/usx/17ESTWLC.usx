  <para style="p"><verse number="1" style="v" sid="EST 10:1"/><char style="w" closed="true" strong="H7760">וַיָּשֶׂם֩</char> <char style="w" closed="true" strong="H4428">הַמֶּ֨לֶךְ</char> <char style="w" closed="true" strong="H0325">אחשרש</char> ׀ <char style="w" closed="true" strong="H4522">מַ֛ס</char> <char style="w" closed="true" strong="H5921">עַל</char>־<char style="w" closed="true" strong="H0776">הָאָ֖רֶץ</char> <char style="w" closed="true" strong="H0339">וְאִיֵּ֥י</char> <char style="w" closed="true" strong="H3220">הַיָּֽם</char>׃  
<verse eid="EST 10:1"/><verse number="2" style="v" sid="EST 10:2"/><char style="w" closed="true" strong="H3605">וְכָל</char>־<char style="w" closed="true" strong="H4639">מַעֲשֵׂ֤ה</char> <char style="w" closed="true" strong="H8633">תָקְפּוֹ֙</char> <char style="w" closed="true" strong="H1369">וּגְב֣וּרָת֔וֹ</char> <char style="w" closed="true" strong="H6575">וּפָרָשַׁת֙</char> <char style="w" closed="true" strong="H1420">גְּדֻלַּ֣ת</char> <char style="w" closed="true" strong="H4782">מָרְדֳּכַ֔י</char> <char style="w" closed="true" strong="H0834">אֲשֶׁ֥ר</char> <char style="w" closed="true" strong="H1431">גִּדְּל֖וֹ</char> <char style="w" closed="true" strong="H4428">הַמֶּ֑לֶךְ</char> <char style="w" closed="true" strong="H3808">הֲלוֹא</char>־<char style="w" closed="true" strong="H1992">הֵ֣ם</char> <char style="w" closed="true" strong="H3789">כְּתוּבִ֗ים</char> <char style="w" closed="true" strong="H5921">עַל</char>־<char style="w" closed="true" strong="H5612">סֵ֙פֶר֙</char> <char style="w" closed="true" strong="H1697">דִּבְרֵ֣י</char> <char style="w" closed="true" strong="H3117">הַיָּמִ֔ים</char> <char style="w" closed="true" strong="H4428">לְמַלְכֵ֖י</char> <char style="w" closed="true" strong="H4074">מָדַ֥י</char> <char style="w" closed="true" strong="H6539">וּפָרָֽס</char>׃  
<verse eid="EST 10:2"/><verse number="3" style="v" sid="EST 10:3"/><char style="w" closed="true" strong="H3588">כִּ֣י</char> ׀ <char style="w" closed="true" strong="H4782">מָרְדֳּכַ֣י</char> <char style="w" closed="true" strong="H3064">הַיְּהוּדִ֗י</char> <char style="w" closed="true" strong="H4932">מִשְׁנֶה֙</char> <char style="w" closed="true" strong="H4428">לַמֶּ֣לֶךְ</char> <char style="w" closed="true" strong="H0325">אֲחַשְׁוֵר֔וֹשׁ</char> <char style="w" closed="true" strong="H1419">וְגָדוֹל֙</char> <char style="w" closed="true" strong="H3064">לַיְּהוּדִ֔ים</char> <char style="w" closed="true" strong="H7521">וְרָצ֖וּי</char> <char style="w" closed="true" strong="H7230">לְרֹ֣ב</char> <char style="w" closed="true" strong="H0251">אֶחָ֑יו</char> <char style="w" closed="true" strong="H1875">דֹּרֵ֥שׁ</char> <char style="w" closed="true" strong="H2896">טוֹב֙</char> <char style="w" closed="true" strong="H5971">לְעַמּ֔וֹ</char> <char style="w" closed="true" strong="H1696">וְדֹבֵ֥ר</char> <char style="w" closed="true" strong="H7965">שָׁל֖וֹם</char> <char style="w" closed="true" strong="H3605">לְכָל</char>־<char style="w" closed="true" strong="H2233">זַרְעֽוֹ</char>׃   <verse eid="EST 10:3"/></para>
